# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Saurabh Dada — surfaced as direct contact on /app/performances
NEXT_PUBLIC_GURU_WHATSAPP=+91XXXXXXXXXX
NEXT_PUBLIC_GURU_PHONE=+91XXXXXXXXXX

# WhatsApp group invite link (only verified shishyas see it)
NEXT_PUBLIC_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/XXXXXXXXXXXXXXXX

# --- Signup-help admin contact (shown when a new user has no code) ---
# Keep separate from the guru so Saurabh Dada doesn't get "I don't have a code" pings.
NEXT_PUBLIC_ADMIN_NAME=Admin name
NEXT_PUBLIC_ADMIN_WHATSAPP=+91XXXXXXXXXX
NEXT_PUBLIC_ADMIN_PHONE=+91XXXXXXXXXX

# --- Server-only: secret used to derive today's shishya code (HOTP-style).
# Any long random string. Don't ship this to the client. Rotate to invalidate
# all past codes immediately. ---
SHISHYA_CODE_SECRET=replace-with-a-long-random-string

# App URL (used in some places; Vercel sets it automatically)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
